# Ikarus — real email (Resend) configuration.
# Copy this file to `.env`, fill in your values, and load it before running.
# NEVER commit a real key. `.env` is gitignored; `.env.example` is the template.

# Switch the email sink on. "mock" (default) never sends; "resend" sends real mail.
IKARUS_SINK=resend

# Your Resend API key (https://resend.com → API Keys). Keep this secret.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Sender. "onboarding@resend.dev" is Resend's sandbox and ONLY delivers to the
# account owner's email. For arbitrary recipients, verify a domain in Resend.
IKARUS_EMAIL_FROM=onboarding@resend.dev

# Hard safety backstop: the real sink only sends to addresses on this list
# (comma-separated, case/space-insensitive). Empty list => nothing is sent.
IKARUS_ALLOWED_RECIPIENTS=gab.gud.susc@gmail.com,gab.gud.susc+attacker@gmail.com

# Optional: point the demo's scenario addresses at your own inbox.
IKARUS_TRUSTED_RECIPIENT=gab.gud.susc@gmail.com
IKARUS_ATTACKER_ADDR=gab.gud.susc+attacker@gmail.com
