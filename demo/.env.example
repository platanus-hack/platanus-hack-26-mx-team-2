# Ikarus local config. Copy to `.env` (git-ignored) and edit. Real env vars win.
# The web UI auto-loads `.env`; restart the server after changing it.

# --- Real email send (the "Enviar 1 correo real" button) ---
# Leave unset to stay in mock (nothing is sent).
# IKARUS_SINK=resend
# RESEND_API_KEY=re_your_key_here
# IKARUS_EMAIL_FROM=onboarding@resend.dev
# Allowlist (comma-separated): a real send only goes to these addresses.
# IKARUS_ALLOWED_RECIPIENTS=you@example.com

# --- LLM provider for the live flow + chat (or pick it in the UI bar) ---
# IKARUS_LLM_PROVIDER=lmstudio      # mock | lmstudio | openai | claude
# IKARUS_CHAT_MODEL=google/gemma-3-12b
# IKARUS_OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
