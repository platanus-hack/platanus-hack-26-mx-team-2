# Vite SPA — public env (safe to ship to the browser).
# Supabase project URL + anon key (login). Without these the app shows a clear
# "Supabase not configured" message on the sign-in screen.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Where the REST API lives in dev (proxied at /api). Defaults to localhost:8787.
VITE_API_TARGET=http://localhost:8787

# Public MCP endpoint shown on the Connect page (server origin + /mcp).
# Defaults to http://localhost:8787/mcp.
VITE_MCP_URL=http://localhost:8787/mcp
