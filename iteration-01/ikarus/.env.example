# Master key for AES-256-GCM credential encryption (32 bytes, base64).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
IKARUS_ENC_KEY=

# Supabase Postgres (Prisma)
DATABASE_URL=          # pooled (pgbouncer) connection for the app
DIRECT_URL=            # direct connection for migrations

# Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=   # used by the server to verify UI session JWTs

# Workspace the MCP endpoint resolves from the DB (must match prisma/seed.ts)
IKARUS_WORKSPACE_USER=demo-user
# Server runtime (optional)
PORT=8787
WEB_ORIGIN=http://localhost:5173    # CORS allow-origin for the SPA
# Optional: real LLM via env when NOT configured per-user in the DB/UI.
# Provider is "anthropic" | "openai". Leave blank to use stubs.
PLANNER_PROVIDER=
PLANNER_MODEL=
PLANNER_API_KEY=
QUARANTINE_PROVIDER=
QUARANTINE_MODEL=
QUARANTINE_API_KEY=