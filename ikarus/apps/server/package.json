{
  "name": "@ikarus/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=true prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@ikarus/gateway": "workspace:*",
    "@ikarus/interpreter": "workspace:*",
    "@ikarus/llm": "workspace:*",
    "@ikarus/policy": "workspace:*",
    "@ikarus/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "@prisma/client": "^5.22.0",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
